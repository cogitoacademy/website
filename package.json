{
  "name": "cogito-acad",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "typescript": "^5"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:native": "turbo -F native dev",
    "dev:web": "turbo -F web dev",
    "format": "oxlint && oxfmt --write",
    "deploy": "turbo -F studio deploy",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@phosphor-icons/react": "^2.1.10",
    "@sanity/vision": "^5.11.0",
    "dotenv": "catalog:",
    "sanity": "^5.11.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.0",
    "oxfmt": "^0.19.0",
    "oxlint": "^1.34.0",
    "turbo": "^2.8.10",
    "typescript": "^5.9.3"
  },
  "packageManager": "bun@1.3.2"
}
